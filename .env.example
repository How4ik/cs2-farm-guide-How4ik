# Скопируйте в Netlify → Site settings → Environment variables

# Секрет для подписи сессии (минимум 16 символов, сгенерируйте случайную строку)
AUTH_SECRET=change-me-to-long-random-string

# Ключи доступа через запятую (node scripts/generate-access-keys.js 20)
ACCESS_KEYS=XXXX-XXXX-XXXX-XXXX-XXXX,YYYY-YYYY-YYYY-YYYY-YYYY
