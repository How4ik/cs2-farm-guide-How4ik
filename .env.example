# Локальная сборка: скопируйте в .env или положите ключи в access-keys.txt

# Ключи доступа (через запятую или с новой строки)
ACCESS_KEYS=XXXX-XXXX-XXXX-XXXX-XXXX,YYYY-YYYY-YYYY-YYYY-YYYY

# Supabase (для привязки «один ключ — одно устройство» глобально)
# 1. Создайте проект на https://supabase.com
# 2. SQL Editor → выполните supabase/setup.sql
# 3. Settings → API → скопируйте URL и anon public key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
