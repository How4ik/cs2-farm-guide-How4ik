# Netlify → Site settings → Environment variables

# Секрет для подписи сессии (минимум 16 символов)
AUTH_SECRET=change-me-to-long-random-string

# Ключи доступа (лимит Netlify: 5000 символов на переменную)
ACCESS_KEYS=XXXX-XXXX-XXXX-XXXX-XXXX,YYYY-YYYY-YYYY-YYYY-YYYY
ACCESS_KEYS_2=ZZZZ-ZZZZ-ZZZZ-ZZZZ-ZZZZ

# GitHub Pages (legacy, слабая защита) — только если остаётесь на GitHub
SUPABASE_URL=
SUPABASE_ANON_KEY=
